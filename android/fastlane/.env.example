# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is git-ignored — never commit real credentials.
#
# fastlane auto-loads fastlane/.env. To keep separate values per flavor you
# can instead use fastlane/.env.dev / .env.staging / .env.prod and select one
# with `bundle exec fastlane beta flavor:prod --env prod`.

# --- Google Play service account ------------------------------------------
# Create a service account in Google Cloud, grant it access in the Play
# Console (Users and permissions), download its JSON key, and store the file
# OUTSIDE the repo. Point this at that file (absolute path is most robust).
PLAY_STORE_JSON_KEY_PATH=/absolute/path/to/play-store-service-account.json

# --- App identifiers ------------------------------------------------------
# Base applicationId; the lane appends the per-flavor suffix (.dev / .staging,
# prod has none). Matches applicationId in android/app/build.gradle.kts.
ANDROID_PACKAGE_NAME_BASE=com.lucistudio.flutter_starter_template

# Optional: override how the Flutter SDK is invoked. Defaults to "fvm flutter".
# In CI where `flutter` is already on PATH, set: FLUTTER_CMD=flutter
# FLUTTER_CMD=flutter
