#!/usr/bin/env bash
#
# Pre-push guard: runs the same fast static checks as the CI "Analyze & Test"
# job so formatting/analyzer problems are caught locally instead of failing CI.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Bypass in an emergency:
#   git push --no-verify
#
set -euo pipefail

# Prefer the FVM-pinned SDK (this repo pins Flutter via .fvmrc); fall back to a
# plain toolchain if FVM is not installed.
if command -v fvm >/dev/null 2>&1; then
  dart() { fvm dart "$@"; }
  flutter() { fvm flutter "$@"; }
  format_fix_cmd="fvm dart format"
else
  format_fix_cmd="dart format"
fi

if ! command -v dart >/dev/null 2>&1 || ! command -v flutter >/dev/null 2>&1; then
  echo "✖ Missing required tooling: dart/flutter not found in PATH." >&2
  echo "  Install the Flutter SDK or FVM and retry (or skip with --no-verify)." >&2
  exit 1
fi

# Generated code (*.g.dart, *.freezed.dart, etc.) is git-ignored, so a clean
# tree has none and analyze would fail on missing sources. Generate first,
# mirroring CI. Fast once build_runner's cache is warm.
echo "▶ pre-push: generating code (build_runner)…"
if ! dart run build_runner build --delete-conflicting-outputs; then
  echo "✖ Code generation failed. Resolve build_runner errors before pushing." >&2
  exit 1
fi

# `dart format .` recursively walks the entire cwd including build artifacts
# (e.g. `build/ios/SourcePackages/` from Xcode 26+ SPM downloads) that are
# not under our control. Scoping to the project source dirs keeps the check
# fast and avoids false positives from third-party generated code.
#
# Each entry is checked individually so a missing dir (e.g. `bin/` in a
# minimal project) does not break the hook.
echo "▶ pre-push: verifying formatting (dart format)…"
format_paths=()
for d in lib test bin packages integration_test; do
  [ -d "$d" ] && format_paths+=("$d")
done
if ! dart format --output=none --set-exit-if-changed "${format_paths[@]}"; then
  echo "✖ Formatting issues found. Fix with: ${format_fix_cmd} ${format_paths[*]}" >&2
  exit 1
fi

echo "▶ pre-push: analyzing (flutter analyze)…"
if ! flutter analyze; then
  echo "✖ Analyzer issues found. Resolve them before pushing." >&2
  exit 1
fi

echo "✓ pre-push checks passed"
