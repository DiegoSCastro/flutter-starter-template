#!/usr/bin/env bash
#
# Pre-push guard: runs the same fast static checks as the CI "Analyze & Test"
# job so formatting/analyzer problems are caught locally instead of failing CI.
#
# Enable once per clone:
#   git config core.hooksPath .githooks
#
# Bypass in an emergency:
#   git push --no-verify
#
set -euo pipefail

# Prefer the FVM-pinned SDK (this repo pins Flutter via .fvmrc); fall back to a
# plain toolchain if FVM is not installed.
#
# Note: we use `flutter pub run` instead of `dart run build_runner` because
# the standalone `dart` binary cannot resolve packages that declare
# `sdk: flutter` in their environment (e.g. `go_router_builder` 4.x). The
# `flutter` wrapper knows where the Flutter SDK lives and sets the right
# constraints.
if command -v fvm >/dev/null 2>&1; then
  flutter() { fvm flutter "$@"; }
  dart() { fvm dart "$@"; }
  format_fix_cmd="fvm flutter pub run dart format"
else
  format_fix_cmd="flutter pub run dart format"
fi

if ! command -v flutter >/dev/null 2>&1; then
  echo "✖ Missing required tooling: flutter not found in PATH." >&2
  echo "  Install the Flutter SDK or FVM and retry (or skip with --no-verify)." >&2
  exit 1
fi

# `flutter pub get` is implicit before any `flutter pub run` — but call it
# explicitly so the error message is clear when lock-file drift is the cause.
echo "▶ pre-push: resolving dependencies (flutter pub get)…"
if ! flutter pub get; then
  echo "✖ Dependency resolution failed. See https://dart.dev/tools/pub/troubleshoot." >&2
  exit 1
fi

# Generated code (*.g.dart, *.freezed.dart, etc.) is git-ignored, so a clean
# tree has none and analyze would fail on missing sources. Generate first,
# mirroring CI. Fast once build_runner's cache is warm.
echo "▶ pre-push: generating code (build_runner)…"
if ! flutter pub run build_runner build --delete-conflicting-outputs; then
  echo "✖ Code generation failed. Resolve build_runner errors before pushing." >&2
  exit 1
fi

# `dart format .` recursively walks the entire cwd including build artifacts
# (e.g. `build/ios/SourcePackages/` from Xcode 26+ SPM downloads) that are
# not under our control. Scoping to the project source dirs keeps the check
# fast and avoids false positives from third-party generated code.
#
# Each entry is checked individually so a missing dir (e.g. `bin/` in a
# minimal project) does not break the hook.
echo "▶ pre-push: verifying formatting (dart format)…"
format_paths=()
for d in lib test bin packages integration_test; do
  [ -d "$d" ] && format_paths+=("$d")
done
if ! dart format --output=none --set-exit-if-changed "${format_paths[@]}" 2>/dev/null; then
  # `dart format` standalone fails on projects that pull in packages with
  # `sdk: flutter` constraints (the standalone `dart` binary has no Flutter
  # SDK context). Fall back to the Flutter wrapper.
  if ! flutter pub run dart format --output=none --set-exit-if-changed "${format_paths[@]}"; then
    echo "✖ Formatting issues found. Fix with: ${format_fix_cmd} ${format_paths[*]}" >&2
    exit 1
  fi
fi

echo "▶ pre-push: analyzing (flutter analyze)…"
if ! flutter analyze; then
  echo "✖ Analyzer issues found. Resolve them before pushing." >&2
  exit 1
fi

echo "✓ pre-push checks passed"
