# Copy this file to `.env` (same directory) and fill in real values.
# `.env` is git-ignored — never commit real credentials.
#
# fastlane auto-loads fastlane/.env. To keep separate values per flavor you
# can instead use fastlane/.env.dev / .env.staging / .env.prod and select one
# with `bundle exec fastlane beta flavor:prod --env prod`.

# --- App Store Connect API key (issued in App Store Connect → Users and
#     Access → Integrations → App Store Connect API). Preferred over an Apple
#     ID + password because it needs no 2FA and works unattended in CI. ------

# The "Key ID" shown next to the key (e.g. ABC123DEF4).
APP_STORE_CONNECT_API_KEY_ID=

# The "Issuer ID" shown above the keys table (a UUID).
APP_STORE_CONNECT_API_ISSUER_ID=

# The contents of the downloaded AuthKey_XXXX.p8, base64-encoded. Generate with:
#   base64 -i AuthKey_XXXXXXXX.p8 | pbcopy     # macOS
# Store the raw .p8 outside the repo; only this base64 string goes in .env.
APP_STORE_CONNECT_API_KEY_CONTENT=

# --- App / team identifiers ----------------------------------------------

# Base bundle id; the lane appends the per-flavor suffix (.dev / .staging,
# prod has none). Matches PRODUCT_BUNDLE_IDENTIFIER in the Xcode project.
IOS_BUNDLE_ID_BASE=com.luci-studio.flutterStarterTemplate

# Apple Developer Team ID (10 chars, e.g. A1B2C3D4E5). Used for signing.
APPLE_TEAM_ID=

# --- Code signing via match ----------------------------------------------
# match keeps the distribution cert + provisioning profiles in a PRIVATE git
# repo. Create an empty private repo, then run `bundle exec fastlane match
# appstore` once locally to populate it before the first release.

# SSH or HTTPS URL of that private repo (e.g. git@github.com:org/ios-certs.git).
MATCH_GIT_URL=

# Passphrase used to encrypt/decrypt the match repo. Keep it safe; it's needed
# on every machine and in CI.
MATCH_PASSWORD=

# Optional: for CI cloning the match repo over HTTPS, a base64 of
# "username:personal_access_token". Leave blank when using SSH.
MATCH_GIT_BASIC_AUTHORIZATION=

# Optional: only needed if your Apple account belongs to multiple App Store
# Connect teams. Leave blank otherwise.
APP_STORE_CONNECT_TEAM_ID=

# Optional: Apple ID email, only used by Appfile/legacy actions. The API key
# above is what actually authenticates the upload, so this can stay blank.
FASTLANE_APPLE_ID=

# Optional: override how the Flutter SDK is invoked. Defaults to "flutter".
# In CI where `flutter` is already on PATH, set: FLUTTER_CMD=flutter
# FLUTTER_CMD=flutter
